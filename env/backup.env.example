# Copy to /opt/anytype-vault/env/backup.env and edit values.
#
# This file is sourced by /opt/anytype-vault/bin/backup.sh (via systemd).
# Do NOT commit your real secrets.

# Backblaze B2 credentials
B2_ACCOUNT_ID="your-b2-key-id"
B2_ACCOUNT_KEY="your-b2-application-key"

# Restic repository URL for B2:
# Format: b2:<bucket-name>:<path>
# Example: b2:anytype-vault:restic
RESTIC_REPOSITORY="b2:your-bucket-name:anytype-vault"

# Restic password (choose a strong one; store in a password manager)
RESTIC_PASSWORD="change-me"

# Optional tuning
# RESTIC_CACHE_DIR="/var/cache/restic"
